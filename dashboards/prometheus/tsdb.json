      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "hide": 0,
        "description": "Scrape job under which Prometheus scrapes itself.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(prometheus_tsdb_head_series, job)",
