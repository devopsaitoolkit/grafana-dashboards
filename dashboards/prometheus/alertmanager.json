  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "hide": 0,
        "description": "Scrape job for your Alertmanager targets.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(alertmanager_alerts, job)",
        "query": {
          "qryType": 1,
          "query": "label_values(alertmanager_alerts, job)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "options": []
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "hide": 0,
        "description": "Alertmanager instance(s); keep All for clustered deployments.",
        "datasource": {
          "type": "prometheus",
