          "editorMode": "code",
          "expr": "100 * sum(rate(cortex_request_duration_seconds_count{route=~\".*push.*|.*write.*\", status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(cortex_request_duration_seconds_count{route=~\".*push.*|.*write.*\"}[5m])), 1)",
          "instant": true,
          "range": false,
          "legendFormat": "write 5xx%",
