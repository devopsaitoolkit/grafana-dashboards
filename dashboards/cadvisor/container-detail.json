  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Host",
        "type": "query",
        "hide": 0,
        "description": "cAdvisor instance (Docker host) the container runs on.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(machine_cpu_cores, instance)",
        "query": {
          "qryType": 1,
          "query": "label_values(machine_cpu_cores, instance)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "options": []
      },
      {
        "name": "name",
        "label": "Container",
        "type": "query",
        "hide": 0,
        "description": "The single container to inspect.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(container_last_seen{instance=\"$instance\", name!=\"\"}, name)",
        "query": {
          "qryType": 1,
          "query": "label_values(container_last_seen{instance=\"$instance\", name!=\"\"}, name)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "options": []
      }
    ]
  },
