      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "count(node_hwmon_temp_celsius{job=\"$job\", instance=~\"$instance\"} > 85) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "hot sensors",
          "refId": "A"
        }
      ],
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      }
    },
