        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(node_vmstat_pgmajfault{job=\"$job\", instance=~\"$instance\"}[5m])) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "majflt/s",
          "refId": "A"
        }
      ],
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 1
      }
