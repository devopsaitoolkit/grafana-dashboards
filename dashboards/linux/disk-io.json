          "editorMode": "code",
          "expr": "sum(rate(node_disk_reads_completed_total{job=\"$job\", instance=~\"$instance\", device!~\"loop.*|ram.*|dm-.*\"}[5m]) + rate(node_disk_writes_completed_total{job=\"$job\", instance=~\"$instance\", device!~\"loop.*|ram.*|dm-.*\"}[5m])) or vector(0)",
          "instant": true,
          "range": false,
