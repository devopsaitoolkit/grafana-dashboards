          "editorMode": "code",
          "expr": "100 * (1 - node_filesystem_avail_bytes{job=\"$job\", instance=~\"$instance\", fstype!~\"tmpfs|overlay|squashfs|nsfs|fuse.*\"} / node_filesystem_size_bytes{job=\"$job\", instance=~\"$instance\", fstype!~\"tmpfs|overlay|squashfs|nsfs|fuse.*\"})",
          "instant": true,
