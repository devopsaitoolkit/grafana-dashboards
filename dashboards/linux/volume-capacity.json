            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(node_filesystem_size_bytes{job=\"$job\", instance=~\"$instance\", fstype!~\"tmpfs|overlay|squashfs|nsfs|fuse.*\"}) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "provisioned",
          "refId": "A"
