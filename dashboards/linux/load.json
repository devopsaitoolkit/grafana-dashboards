          "editorMode": "code",
          "expr": "sum(node_procs_blocked{job=\"$job\", instance=~\"$instance\"}) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "blocked",
          "refId": "A"
        }
      ],
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      }
    },
