      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "count(\n  node_load1{job=\"$job\", instance=~\"$instance\"}\n  > count without (cpu, mode) (node_cpu_seconds_total{job=\"$job\", instance=~\"$instance\", mode=\"idle\"})\n) or vector(0)",
