        "hide": 0,
        "description": "RabbitMQ virtual host (OpenStack usually uses \"/\").",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(rabbitmq_queue_messages_ready{job=\"$job\"}, vhost)",
        "query": {
          "qryType": 1,
          "query": "label_values(rabbitmq_queue_messages_ready{job=\"$job\"}, vhost)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": true,
