        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(rabbitmq_queue_messages_delivered_total{job=\"$job\", vhost=~\"$vhost\"}[5m]))",
          "instant": false,
          "range": true,
          "legendFormat": "delivered/s",
          "refId": "B"
        }
      ],
