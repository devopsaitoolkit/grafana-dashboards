        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(rabbitmq_queue_messages_ready, job)",
        "query": {
          "qryType": 1,
          "query": "label_values(rabbitmq_queue_messages_ready, job)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "options": []
      },
      {
        "name": "vhost",
        "label": "Vhost",
