    },
    {
      "type": "timeseries",
      "title": "New ERROR instances per minute",
      "description": "Positive change in the ERROR count — the rate at which scheduling/placement is failing right now.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
