        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "clamp_min(deriv(count(openstack_nova_server_status{job=\"$job\", cloud=~\"$cloud\", status=\"ERROR\"})[10m:1m]), 0) * 60",
          "instant": false,
          "range": true,
          "legendFormat": "new errors/min",
          "refId": "A"
        }
      ],
      "id": 8,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      }
    },
