            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "count(openstack_nova_server_status{job=\"$job\", cloud=~\"$cloud\", status=\"BUILD\"}) or vector(0)",
          "instant": false,
          "range": true,
          "legendFormat": "build",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "count(openstack_nova_server_status{job=\"$job\", cloud=~\"$cloud\", status=\"ERROR\"}) or vector(0)",
          "instant": false,
          "range": true,
          "legendFormat": "error",
          "refId": "B"
