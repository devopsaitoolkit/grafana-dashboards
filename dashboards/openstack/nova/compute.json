          "editorMode": "code",
          "expr": "count(\n  openstack_nova_vcpus_used{job=\"$job\", aggregate=~\"$aggregate\", hostname=~\"$hostname\"}\n  / openstack_nova_vcpus{job=\"$job\", aggregate=~\"$aggregate\", hostname=~\"$hostname\"} > 4\n) or vector(0)",
