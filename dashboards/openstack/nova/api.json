  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "hide": 0,
        "description": "Prometheus scrape job for your openstack-exporter target.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(openstack_nova_agent_state, job)",
        "query": {
          "qryType": 1,
          "query": "label_values(openstack_nova_agent_state, job)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "options": []
      },
      {
        "name": "cloud",
        "label": "Cloud",
        "type": "query",
        "hide": 0,
        "description": "Cloud/region when running the exporter in multi-cloud mode; All if single-cloud.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(openstack_nova_agent_state{job=\"$job\"}, cloud)",
        "query": {
          "qryType": 1,
          "query": "label_values(openstack_nova_agent_state{job=\"$job\"}, cloud)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "options": []
      },
      {
        "name": "hostname",
        "label": "Hypervisor",
        "type": "query",
        "hide": 0,
        "description": "Compute host(s) to scope agent and workload panels to.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(openstack_nova_agent_state{job=\"$job\", cloud=~\"$cloud\"}, hostname)",
        "query": {
          "qryType": 1,
          "query": "label_values(openstack_nova_agent_state{job=\"$job\", cloud=~\"$cloud\"}, hostname)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "options": []
      }
