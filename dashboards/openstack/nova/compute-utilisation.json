        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "100 * sum(openstack_nova_memory_used_mb{job=\"$job\", aggregate=~\"$aggregate\"}) / sum(openstack_nova_memory_mb{job=\"$job\", aggregate=~\"$aggregate\"}) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "memory",
          "refId": "A"
        }
      ],
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Free allocatable vCPUs",
      "description": "Remaining vCPUs you can still commit before the configured ratio is spent.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
