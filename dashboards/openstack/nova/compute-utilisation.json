  "description": "Allocated-vs-physical resource utilisation for an OpenStack Nova fleet from openstack-exporter: how far vCPU and memory are committed past physical capacity, the overcommit ratio in use, allocatable headroom against your configured ratios, and utilisation broken out per aggregate. Answers \"how oversubscribed are we, and how much more can we safely place?\".",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overcommit & headroom — read these first",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Fleet vCPU overcommit",
      "description": "Allocated vCPUs ÷ physical cores across the fleet. Compare against your cpu_allocation_ratio.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 6
              }
            ]
          },
          "unit": "short",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "showPercentChange": false
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(openstack_nova_vcpus_used{job=\"$job\", aggregate=~\"$aggregate\"}) / sum(openstack_nova_vcpus{job=\"$job\", aggregate=~\"$aggregate\"}) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "ratio",
          "refId": "A"
        }
      ],
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "gauge",
      "title": "Allocatable vCPU headroom",
      "description": "Percent of allocatable vCPU (physical × ratio) still free. Drives \"how many more instances can we place\".",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 15
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "100 * (1 -\n  sum(openstack_nova_vcpus_used{job=\"$job\", aggregate=~\"$aggregate\"})\n  / (sum(openstack_nova_vcpus{job=\"$job\", aggregate=~\"$aggregate\"}) * $ratio)\n)",
          "instant": true,
          "range": false,
          "legendFormat": "headroom",
          "refId": "A"
        }
      ],
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      }
    },
    {
      "type": "gauge",
