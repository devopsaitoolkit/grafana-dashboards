      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "clamp_min(\n  sum(openstack_nova_vcpus{job=\"$job\", aggregate=~\"$aggregate\"}) * $ratio\n  - sum(openstack_nova_vcpus_used{job=\"$job\", aggregate=~\"$aggregate\"}), 0\n) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "free vcpu",
          "refId": "A"
        }
