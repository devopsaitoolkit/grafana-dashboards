    {
      "type": "gauge",
      "title": "InnoDB buffer pool used",
      "description": "Percent of InnoDB buffer pool pages in use (total minus free). Persistently ~100% means the working set exceeds RAM and pages are churning.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "red",
                "value": 98
              }
            ]
          },
          "unit": "percent",
          "min": 0,
