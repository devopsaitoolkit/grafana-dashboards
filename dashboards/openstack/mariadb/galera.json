        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "max(mysql_global_status_wsrep_flow_control_paused{job=\"$job\", instance=~\"$instance\"}) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "paused",
          "refId": "A"
        }
      ],
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 1
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Per-node sync state",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "type": "state-timeline",
      "title": "wsrep state per node",
      "description": "Replication state history per node. Anything other than Synced (4) during steady state needs investigation.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "Joining",
                  "color": "yellow"
                },
                "2": {
                  "text": "Donor/Desynced",
                  "color": "orange"
                },
                "3": {
                  "text": "Joined",
                  "color": "yellow"
                },
                "4": {
                  "text": "Synced",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 4
              }
            ]
