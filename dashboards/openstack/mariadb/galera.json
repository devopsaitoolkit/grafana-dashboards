          "unit": "short",
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 80,
            "spanNulls": false,
            "insertNulls": false,
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "mysql_global_status_wsrep_local_state{job=\"$job\", instance=~\"$instance\"}",
          "instant": false,
          "range": true,
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "id": 7,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      }
    },
    {
      "type": "timeseries",
      "title": "Cluster size over time",
