      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "count(openstack_cinder_service_state{job=\"$job\", service=~\"$service\"} == 0) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "down",
