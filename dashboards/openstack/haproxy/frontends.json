        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(haproxy_frontend_http_requests_total{job=\"$job\", frontend=~\"$frontend\"}[5m])) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      }
    },
