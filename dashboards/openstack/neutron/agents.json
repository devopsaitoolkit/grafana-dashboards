          "editorMode": "code",
          "expr": "count(openstack_neutron_agent_state{job=\"$job\", agent=~\"$agent\"} == 0) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "down",
          "refId": "A"
        }
      ],
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
