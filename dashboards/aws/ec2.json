          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(aws_ec2_cpuutilization_average, job)",
        "query": {
          "qryType": 1,
          "query": "label_values(aws_ec2_cpuutilization_average, job)",
          "refId": "variable"
