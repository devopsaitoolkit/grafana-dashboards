  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "hide": 0,
        "description": "Prometheus scrape job for the CoreDNS pods.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(coredns_dns_requests_total, job)",
