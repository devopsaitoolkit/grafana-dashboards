      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(scheduler_schedule_attempts_total{job=\"$job\", instance=~\"$instance\", result=\"unschedulable\"}[5m])) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "unschedulable",
          "refId": "A"
        }
      ],
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      }
    },
