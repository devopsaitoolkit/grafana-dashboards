        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "(sum(kube_node_status_allocatable{cluster=~\"$cluster\", resource=\"cpu\"})\n - sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", resource=\"cpu\"}))\n/ clamp_min(deriv(sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", resource=\"cpu\"})[6h:30m]), 0.0000000001)",
          "instant": true,
          "range": false,
          "legendFormat": "cpu_seconds",
          "refId": "A"
