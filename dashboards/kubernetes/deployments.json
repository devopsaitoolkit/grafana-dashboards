      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "100 * kube_deployment_status_replicas_available{cluster=~\"$cluster\", namespace=~\"$namespace\"} / clamp_min(kube_deployment_spec_replicas{cluster=~\"$cluster\", namespace=~\"$namespace\"}, 1)",
          "instant": true,
          "range": false,
          "legendFormat": "{{namespace}}/{{deployment}}",
          "refId": "A"
