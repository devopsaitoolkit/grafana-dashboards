        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(kube_deployment_spec_replicas{cluster=~\"$cluster\"}, namespace)",
        "query": {
          "qryType": 1,
