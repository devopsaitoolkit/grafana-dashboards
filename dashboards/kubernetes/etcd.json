          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(etcd_disk_backend_commit_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\"}[5m])))",
          "instant": true,
          "range": false,
          "legendFormat": "commit p99",
          "refId": "A"
