          "editorMode": "code",
          "expr": "100 * sum by (namespace) (kube_resourcequota{cluster=~\"$cluster\", resource=\"requests.cpu\", type=\"used\"}) / sum by (namespace) (kube_resourcequota{cluster=~\"$cluster\", resource=\"requests.cpu\", type=\"hard\"})",
