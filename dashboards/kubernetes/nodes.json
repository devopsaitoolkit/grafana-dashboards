      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "max(\n  100\n  * sum by (node) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", node=~\"$node\", container!=\"\", pod!=\"\"}[5m]))\n  / sum by (node) (kube_node_status_allocatable{cluster=~\"$cluster\", node=~\"$node\", resource=\"cpu\"})\n) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "cpu",
          "refId": "A"
        }
      ],
      "id": 4,
      "gridPos": {
        "h": 8,
