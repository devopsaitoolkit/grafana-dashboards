  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "hide": 0,
        "description": "Prometheus scrape job for the ingress-nginx controller.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(nginx_ingress_controller_requests, job)",
        "query": {
          "qryType": 1,
          "query": "label_values(nginx_ingress_controller_requests, job)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "options": []
      },
      {
