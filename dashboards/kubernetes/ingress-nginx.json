          "editorMode": "code",
          "expr": "sum(nginx_ingress_controller_nginx_process_connections{job=\"$job\", state=\"active\"}) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "active",
          "refId": "A"
