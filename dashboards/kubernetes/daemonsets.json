          "editorMode": "code",
          "expr": "100 * min(\n  kube_daemonset_status_number_ready{cluster=~\"$cluster\", namespace=~\"$namespace\"}\n  / clamp_min(kube_daemonset_status_desired_number_scheduled{cluster=~\"$cluster\", namespace=~\"$namespace\"}, 1)\n) or vector(0)",
