    {
      "type": "gauge",
      "title": "Worst DaemonSet coverage",
      "description": "Lowest ready-vs-desired ratio across all DaemonSets — the least-covered daemon.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
