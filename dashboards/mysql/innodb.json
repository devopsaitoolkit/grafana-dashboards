          "editorMode": "code",
          "expr": "sum(rate(mysql_global_status_innodb_row_lock_time{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(mysql_global_status_innodb_row_lock_waits{instance=~\"$instance\"}[5m])), 1)",
