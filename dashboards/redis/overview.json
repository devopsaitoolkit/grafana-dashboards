      "name": "Grafana",
      "version": "11.1.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Top-level health for Redis instances scraped by redis_exporter: liveness, memory used against maxmemory, keyspace hit ratio, throughput, connected and blocked clients, and evictions. Answers \"is this Redis healthy, and is it about to start evicting or rejecting?\".",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health — read these first",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Redis up",
      "description": "Liveness from redis_exporter. 1 = the exporter reached the instance.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "showPercentChange": false
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "min(redis_up{instance=~\"$instance\"}) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "up",
          "refId": "A"
        }
      ],
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "gauge",
      "title": "Memory used vs maxmemory",
      "description": "Worst instance's memory as a percentage of its maxmemory. Meaningless when maxmemory is 0 (unlimited).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "max(\n  100 * redis_memory_used_bytes{instance=~\"$instance\"}\n  / clamp_min(redis_memory_max_bytes{instance=~\"$instance\"}, 1)\n) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "memory %",
          "refId": "A"
        }
      ],
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      }
    },
    {
      "type": "gauge",
      "title": "Keyspace hit ratio",
      "description": "Share of key lookups that hit over 5m. A low ratio means the cache is cold or under-sized.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "100 * sum(rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m])) / clamp_min(\n    sum(rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m]))\n    + sum(rate(redis_keyspace_misses_total{instance=~\"$instance\"}[5m])), 1)",
          "instant": true,
          "range": false,
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "stat",
