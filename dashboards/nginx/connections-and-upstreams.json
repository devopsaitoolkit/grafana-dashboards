        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(nginx_up, job)",
        "query": {
          "qryType": 1,
          "query": "label_values(nginx_up, job)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "options": []
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "hide": 0,
        "description": "NGINX host(s) to display; supports multi-select.",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(nginx_up{job=\"$job\"}, instance)",
        "query": {
          "qryType": 1,
          "query": "label_values(nginx_up{job=\"$job\"}, instance)",
          "refId": "variable"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "options": []
