          "editorMode": "code",
          "expr": "100 * sum(rate(nginx_vts_server_requests_total{job=\"$job\", host=~\"$host\", code=\"4xx\"}[5m])) / clamp_min(sum(rate(nginx_vts_server_requests_total{job=\"$job\", host=~\"$host\", code=\"total\"}[5m])), 1) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "4xx ratio",
          "refId": "A"
        }
      ],
