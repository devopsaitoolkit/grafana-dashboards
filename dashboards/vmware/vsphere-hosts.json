        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "max(\n  100 * vmware_host_cpu_usage{cluster_name=~\"$cluster\", host_name=~\"$host\"}\n  / clamp_min(vmware_host_cpu_max{cluster_name=~\"$cluster\", host_name=~\"$host\"}, 1)\n) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "max cpu",
          "refId": "A"
        }
