      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "count(up{job=\"$job\"} == 1) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "up",
          "refId": "A"
        }
      ],
      "id": 2,
