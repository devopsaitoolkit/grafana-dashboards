          "expr": "topk(10,\n  100 * sum by (name) (container_fs_usage_bytes{instance=\"$instance\", name!=\"\"})\n  / clamp_min(sum by (name) (container_fs_limit_bytes{instance=\"$instance\", name!=\"\"}), 1))",
          "instant": true,
          "range": false,
          "legendFormat": "{{name}}",
          "refId": "A"
